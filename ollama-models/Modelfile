# COMAC 低配 Windows 环境 - 主力模型 (7B)
# 底层: Qwen2.5-7B-Instruct Q4_K_M
#
# 部署步骤:
#   1. 下载 GGUF 到 .\ollama-models\qwen2.5-7b-instruct-q4_k_m.gguf
#   2. 执行: ollama create comac -f Modelfile
#   3. 验证: ollama list | findstr comac

FROM .\qwen2.5-7b-instruct-q4_k_m.gguf

# 温度 - 国企文档需要稳定输出
PARAMETER temperature 0.3

# 上下文窗口 - 8192 tokens, 适配 16GB RAM 环境
PARAMETER num_ctx 8192

# 最大生成长度 - 2048 tokens
PARAMETER num_predict 2048

PARAMETER stop "<|im_end|>"
