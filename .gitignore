# =============================================================================
# COMAC-LocalAI-Windows .gitignore
# 打包部署时：排除以下内容，仅保留源代码、模板、文档
# =============================================================================

# -----------------------------------------------------------------------------
# Python 运行时产物（必须排除）
# -----------------------------------------------------------------------------
.venv/                    # Python 虚拟环境（独立打包，内含 ~1.5GB 二进制包）
venv/                    # 备选 venv 名称
env/                     # 备选 env 名称
__pycache__/            # Python 字节码缓存
*.py[cod]               # 编译的 Python 字节码
*.pyc
*.pyo
*.pyd

# -----------------------------------------------------------------------------
# 本地运行时文件（必须排除）
# -----------------------------------------------------------------------------
temp/                    # 运行时上传/输出目录（每次启动为空）
logs/                    # 日志文件
*.log                    # 所有日志文件
task_history.db         # SQLite 任务历史数据库
*.db                    # 所有数据库文件

# -----------------------------------------------------------------------------
# Ollama 模型文件（巨大文件，不纳入版本控制）
# -----------------------------------------------------------------------------
ollama-models/*.gguf    # 模型权重文件（用户需自行下载到内网机器）
ollama-models/*.bin
ollama-models/*.fp16
*.gguf                  # 任何位置的 GGUF 模型文件

# -----------------------------------------------------------------------------
# 系统文件
# -----------------------------------------------------------------------------
.DS_Store              # macOS
Thumbs.db              # Windows
desktop.ini            # Windows
*.swp                  # Vim 临时文件
*.swo
*~                     # Emacs 临时文件

# -----------------------------------------------------------------------------
# IDE 和编辑器
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-*
*.code-workspace

# -----------------------------------------------------------------------------
# 测试覆盖产物
# -----------------------------------------------------------------------------
htmlcov/
.coverage
.pytest_cache/
.tox/
.mypy_cache/

# -----------------------------------------------------------------------------
# 部署产物（运行时生成）
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.whl                    # wheel 包

# -----------------------------------------------------------------------------
# 安全文件（不纳入版本控制）
# -----------------------------------------------------------------------------
.env                    # 环境变量文件（含密码/密钥）
*.pem                   # 证书文件
*.key                   # 密钥文件
