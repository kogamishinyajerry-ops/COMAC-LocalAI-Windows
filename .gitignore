# COMAC-LocalAI-Windows .gitignore
# Exclude runtime artifacts, secrets, and build products.
# Deployment packages (COMAC-*.zip) are explicitly committed.

# Python virtual environment
.venv/
venv/
env/
.py311/
.py311_venv/
.py311full/
.build_venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Runtime temp/logs
temp/
logs/
*.log

# Personal secrets
.env

# Ollama runtime cache
ollama-cache/
vector_index/

# Large extracted runtimes
tools/ollama/
tools/python/
tools/ollama-windows-amd64.zip
tools/python-embed.zip

# Wheels cache (covered by COMAC-python-wheels.zip)
python-wheels/
python-wheels-new/

# Build artifacts
build/
dist/
installer/
*.db

# Transfer zips (only COMAC-*.zip are committed)
*.zip
!COMAC-offline-sources.zip
!COMAC-python-wheels.zip

# System junk
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.bak
