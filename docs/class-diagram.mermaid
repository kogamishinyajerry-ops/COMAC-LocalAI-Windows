classDiagram
    %% ============================================================
    %% RAG 引擎核心类（F7 修复后）
    %% ============================================================

    class OllamaRAG {
        -str embed_model
        -str llm_model
        -int chunk_size
        -int chunk_overlap
        -OllamaClient _embed_client
        -OllamaClient _llm_client
        -bool _embed_available
        -SimpleVectorStore vector_store
        +index_documents(path, recursive) int
        +index_file(file_path) int
        +sync_index(path, recursive) Dict
        +query(question, top_k, context_mode) str
        +rebuild_index(path) int
        +get_stats() Dict
        -_check_embed_model() bool
        -_get_embedding(text) List~float~
        -_chunk_text(text) List~str~
        -_compute_hash(content) str
        -_remove_from_index(file_path) void
    }

    class SimpleVectorStore {
        -Path index_path
        -Dict~str,Document~ documents
        -Dict~str,Chunk~ chunks
        +add_chunk(chunk, doc_id) void
        +search(query_embedding, top_k) List~Tuple~
        +clear() void
        -_load_index() void
        -_save_index() void
        -_search_naive(query_embedding, top_k) List~Tuple~
    }

    class Chunk {
        +str id
        +str content
        +Dict metadata
        +List~float~ embedding
    }

    class Document {
        +str path
        +List~Chunk~ chunks
        +str content_hash
    }

    %% ============================================================
    %% 解析器类层次（F7 修复后）
    %% ============================================================

    class BaseParser {
        <<abstract>>
        +parse(file_path)* Document
        +extract_text(file_path)* str
    }

    class ParserFactory {
        -Dict _parsers$
        +get_parser(file_path)$ BaseParser
        +parse(file_path)$ Document
        +extract_text(file_path)$ str
    }

    class ExcelParser {
        +parse(file_path) Document
        +extract_text(file_path) str
        Note: F7修复 — .csv用pd.read_csv()<br/>.xlsx/.xls用pd.ExcelFile()
    }

    class WordParser {
        +parse(file_path) Document
        +extract_text(file_path) str
    }

    class PDFParser {
        +parse(file_path) Document
        +extract_text(file_path) str
    }

    class PPTParser {
        +parse(file_path) Document
        +extract_text(file_path) str
    }

    class TextParser {
        +parse(file_path) Document
        +extract_text(file_path) str
    }

    %% ============================================================
    %% Ollama 客户端（无变更）
    %% ============================================================

    class OllamaClient {
        -str model
        -str host
        +generate(prompt, temperature, num_predict) str
        +embeddings(text) Dict
        +list_models() List~str~
        +check_model() bool
        Note: list_models() 使用 response.models 属性
    }

    %% ============================================================
    %% 关系
    %% ============================================================

    OllamaRAG *-- SimpleVectorStore : contains
    OllamaRAG *-- OllamaClient : uses (2 instances)
    SimpleVectorStore o-- Chunk : stores
    SimpleVectorStore o-- Document : stores
    Document o-- Chunk : contains

    BaseParser <|-- ExcelParser : extends
    BaseParser <|-- WordParser : extends
    BaseParser <|-- PDFParser : extends
    BaseParser <|-- PPTParser : extends
    BaseParser <|-- TextParser : extends

    ParserFactory --> BaseParser : creates/manages
    OllamaRAG ..> ParserFactory : uses (F7 new)
    OllamaRAG --> OllamaClient : uses for embeddings
